---
import logo from "/src/assets/shared/logo.svg";
import icon from "/src/assets/shared/icon-hamburger.svg"
---

<header class="header">
    <img src={logo.src} alt="logo" />
    <hr />
    <ul class="nav">
        <li><a href="/">00 HOME</a></li>
        <li><a href="/">01 DESTINATIONS</a></li>
        <li><a href="/">02 CREW</a></li>
        <li><a href="/">03 TECHNOLOGY</a></li>
    </ul>
    <button class="icon" ><img src={icon.src} alt="toggle" /></button>
</header>

<style>
    /* You also can write css code */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        /* padding:0.5rem; */
        padding-bottom: 0px;
        padding-right: 0px;
        margin-top:1.3rem ;
    }
    img{
        width: 35px;
        margin-left: 20px;
        margin-right: 20px;
        position: static;
    }
    .ul a{
        font-weight: 100 !important;
    }
    hr{
        width: 37rem;
        border: 0;
        border-top: 0.1px solid #e7e7e759;
        left: 4rem;
        position: relative;
        z-index: 1;
    }
    .nav{
        display: flex;
        justify-content: space-evenly;
        min-width: 640px;
        padding: 3.2vh;
        background-color: rgba(255, 255, 255, 16%);
        backdrop-filter: blur(50px);
        color: white;
        font-family: "BarlowCondensed-Regular";
        font-weight: 300;
    }
    .li a:hover,
    .li.a:focus{
        border: 0;
        border-bottom: 2px solid #f1f1f1;
        padding-bottom: 1.3rem;
    }
    .icon {
        display: none;
    }

    .expanded {
    display: unset;
    }
    ul{
        display: block;
        list-style-type: 0px;
    }

    @media screen and (max-width: 768px) {
        hr{
            display: none;
        }
        .nav{
            width: -webkit-fill-available;
            min-width: 0px;
        }

        .header{
            margin-top: 0px;
        }

    }

    @media screen and (max-width: 375px) {
        .nav{
            display: none;
            position: absolute;
            top: 4rem;
            height: -webkit-fill-available;
            flex-direction: column;
            justify-content: space-evenly;
            align-items: center;

        }
        .header{
            
            padding: 1rem;
            padding-left: 0;
        }
        .icon {
            display: block;
            position: absolute;
            right: 20px;
            top: 20px;
            z-index: 1;
        }

    }

</style>

<script>
    
    const buttom = document.getElementsByClassName("icon")[0];
    const nav = document.getElementsByClassName("nav")[0] as HTMLElement;

    buttom.addEventListener("click", () => {
        nav.style.display = nav.style.display === "none" ? "inherit" : "none";
    });
</script>