---
import HomeBgSmall from "../assets/home/background-home-mobile.jpg";
import HomeBgMedium from "../assets/home/background-home-tablet.jpg";
import HomeBgBig from "../assets/home/background-home-desktop.jpg";
---

<picture aria-hidden="true">
  <source media="(max-width: 480px)" srcset={HomeBgSmall.src} />
  <source media="(max-width: 768px)" srcset={HomeBgMedium.src} />
  <img src={HomeBgBig.src} class="w-full h-screen fixed top-0 left-0 object-cover -z-10" />
</picture>
