---
import BgSmall from "../assets/destination/background-destination-mobile.jpg";
import BgMedium from "../assets/destination/background-destination-tablet.jpg";
import BgBig from "../assets/destination/background-destination-desktop.jpg";
---

<picture aria-hidden="true">
  <source media="(max-width: 480px)" srcset={BgSmall.src} />
  <source media="(max-width: 768px)" srcset={BgMedium.src} />
  <img src={BgBig.src} class="w-full h-[100dvh] fixed top-0 left-0 object-cover -z-10" />
</picture>
