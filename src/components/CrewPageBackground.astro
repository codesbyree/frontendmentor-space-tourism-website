---
import BgSmall from "../assets/crew/background-crew-mobile.jpg";
import BgMedium from "../assets/crew/background-crew-tablet.jpg";
import BgBig from "../assets/crew/background-crew-desktop.jpg";
---

<picture aria-hidden="true">
  <source media="(max-width: 480px)" srcset={BgSmall.src} />
  <source media="(max-width: 768px)" srcset={BgMedium.src} />
  <img src={BgBig.src} class="w-full h-screen fixed top-0 left-0 object-cover -z-10" />
</picture>
