---
import Layout from "../layouts/Layout.astro";

import DestinationPageBackground from "../components/DestinationPageBackground.astro";
import DestinationSelector from "../components/DestinationSelector";
---

<Layout>
  <main class="p-6 flex-1 pt-[112px] h-[100dvh] flex md:p-10 md:pt-[136px] xl:pt-[184px]">
    <section class="flex-1 gap-6 flex flex-col xl:max-w-[1110px] xl:mx-auto">
      <h1 class="font-sans-codensed tracking-widest text-base text-center md:text-left md:text-xl">
        <span class="text-white/25 font-bold mr-6" aria-hidden="true">01</span><span class="text-white"
          >PICK YOUR DESTINATION</span
        >
      </h1>

      <DestinationSelector client:visible />
    </section>

    <DestinationPageBackground />
  </main>
</Layout>
