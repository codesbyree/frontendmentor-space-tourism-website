---
import Layout from "../layouts/Layout.astro";

import CrewPageBackground from "../components/CrewPageBackground.astro";
---

<Layout>
  <main class="relative min-h-screen overflow-hidden">
    <section
      class="h-full w-full p-6 flex flex-col gap-8 max-w-screen-xl pt-32 md:px-10 md:py-32 xl:max-w-screen-xl xl:mx-auto xl:gap-36 xl:pb-0"
    >
      <h1 class="font-sans-codensed tracking-widest text-base text-center md:text-left md:text-xl">
        <span class="text-white/25 font-bold mr-6" aria-hidden="true">01</span><span class="text-white"
          >MEET YOUR CREW</span
        >
      </h1>
    </section>

    <CrewPageBackground />
  </main>
</Layout>
